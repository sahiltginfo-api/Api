# Ultra-Premium Telegram Bot v3.0 - Environment Configuration
# Copy this file to .env and fill in your values
# Then use: python main_premium.py

# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 BOT CREDENTIALS (Required)
# ═══════════════════════════════════════════════════════════════════════════════

# Your bot token from @BotFather
# Format: 123456789:ABCdefGHIjklmnoPQRstuvWXYZabcdefgh
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram user ID (get from @userinfobot)
# Format: 987654321
BOT_OWNER_ID=6512242172

# Group ID for logs (set to 0 to disable)
# Format: -1001234567890
LOGS_GROUP_ID=-1003912920759

# Channel for force subscription (optional)
# Format: @your_channel
FORCE_SUBSCRIBE_CHANNEL=@Kasukabe00

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 API SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# OSINT API Endpoint
# Keep as-is unless you have custom API
BASE_API=https://sbsakib.eu.cc/apis/

# API Key (get from your API provider)
# Format: alphanumeric key
API_KEY=Demo

# API Request Timeout (seconds)
# Range: 5-30, default 15
API_TIMEOUT=15

# Cooldown between requests per user (seconds)
# Default: 2 seconds for free users
API_COOLDOWN_SECONDS=2

# ═══════════════════════════════════════════════════════════════════════════════
# 💎 PREMIUM SYSTEM SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Premium user cooldown (seconds)
# Default: 0.5 seconds (much faster than free)
PREMIUM_API_COOLDOWN=0.5

# Premium users daily search limit
# Recommendation: 500-1000, or leave as unlimited with -1
PREMIUM_DAILY_LIMIT=500

# Free users daily search limit
# Default: 50 searches per day
FREE_DAILY_LIMIT=50

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 DATABASE SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# SQLite database file path
# Keep as-is for local database
DATABASE_PATH=osint_bot.db

# Optional: Enable database encryption
# For SQLite: use SQLCipher (requires additional setup)
# DATABASE_ENCRYPTION=false

# ═══════════════════════════════════════════════════════════════════════════════
# ⚙️ ADMIN SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Additional admin user IDs (comma-separated)
# Example: 111111111,222222222,333333333
ADDITIONAL_ADMINS=6512242172

# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 UI/UX SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Default theme (dark_luxury, neon_glass, aqua_neon, ai_os, royal_elite, space, mystic)
DEFAULT_THEME=dark_luxury

# Enable animations and fancy formatting
ENABLE_ANIMATIONS=true

# Show loading indicators
SHOW_LOADING=true

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable anti-spam protection
ANTI_SPAM_ENABLED=true

# Max commands per 10 seconds per user
ANTI_SPAM_LIMIT=5

# Enable rate limiting
RATE_LIMITING_ENABLED=true

# Global rate limit (requests per minute)
GLOBAL_RATE_LIMIT=1000

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 ANALYTICS SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable usage analytics
ANALYTICS_ENABLED=true

# Log all searches
LOG_SEARCHES=true

# Keep logs for X days before cleanup
LOG_RETENTION_DAYS=30

# ═══════════════════════════════════════════════════════════════════════════════
# 🎮 GAMIFICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable achievement system
ACHIEVEMENTS_ENABLED=true

# Enable XP/Level system
LEVELING_ENABLED=true

# Enable leaderboards
LEADERBOARDS_ENABLED=true

# Enable referral system
REFERRAL_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 LOGGING SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable file logging
FILE_LOGGING=true

# Log file name
LOG_FILE=bot.log

# Max log file size before rotation (MB)
LOG_FILE_SIZE=10

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 DEPLOYMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Bot mode (polling or webhook)
# polling = continuously check for messages (default, easier)
# webhook = receive updates via HTTP (requires public IP/domain)
BOT_MODE=polling

# Polling interval (seconds, only for polling mode)
POLLING_INTERVAL=1

# ═══════════════════════════════════════════════════════════════════════════════
# 📞 SUPPORT & CONTACT
# ═══════════════════════════════════════════════════════════════════════════════

# Support group/channel URL
SUPPORT_URL=https://t.me/Kasukabe01

# Support bot username
SUPPORT_BOT=@Astroniixx

# ═══════════════════════════════════════════════════════════════════════════════
# 🎁 PROMOTIONS & LINKS
# ═══════════════════════════════════════════════════════════════════════════════

# Main channel for announcements
MAIN_CHANNEL=https://t.me/+ZiRV3fue70hhMWVl

# Website or GitHub
PROJECT_URL=https://github.com/your_repo

# ═══════════════════════════════════════════════════════════════════════════════
# ⚡ OPTIONAL ADVANCED SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable webhook mode (requires setup)
# WEBHOOK_URL=https://your-domain.com/webhook

# Redis configuration (for advanced caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Database backup settings
# BACKUP_DATABASE=true
# BACKUP_INTERVAL_HOURS=24

# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# 1. COPY THIS FILE
#    cp .env.example .env

# 2. EDIT .env WITH YOUR VALUES
#    • BOT_TOKEN: Required - from @BotFather
#    • BOT_OWNER_ID: Required - your Telegram user ID
#    • API_KEY: Required - from your API provider
#    • Others: Use defaults or customize as needed

# 3. RUN BOT
#    python main_premium.py

# 4. TEST IN TELEGRAM
#    Send /start to your bot

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 NOTES
# ═══════════════════════════════════════════════════════════════════════════════

# • Never commit .env to git (add to .gitignore)
# • Keep BOT_TOKEN secret
# • Use strong API keys
# • Backup database regularly
# • Monitor logs for errors
# • Enable security features in production

# ═══════════════════════════════════════════════════════════════════════════════
